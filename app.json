{
  "expo": {
    "name": "DecorAI-GH",
    "slug": "DecorAI-GH",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "decoraigh",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "PUT_IOS_GOOGLE_MAPS_KEY_HERE"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "PUT_ANDROID_GOOGLE_MAPS_KEY_HERE"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0B",
          "dark": {
            "backgroundColor": "#0B0B0B",
            "image": "./assets/images/logo.png"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "DecorAI GH needs camera access to photograph your space for AI decoration previews.",
          "microphonePermission": false,
          "photosPermission": "DecorAI GH needs photo library access to upload your space photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "DecorAI GH saves your AI decoration designs to your photo library.",
          "savePhotosPermission": "DecorAI GH saves finished designs to your camera roll.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DecorAI GH uses your location to show nearby decorators and guide you to them."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
