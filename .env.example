# ═══════════════════════════════════════════════════════════════════════════
# DecorAI GH — copy this file to `.env` and paste real values.
# Never commit your real `.env`.
# ═══════════════════════════════════════════════════════════════════════════

# ── Required: Neon Postgres (Java Spring API) ───────────────────────────────
# Neon dashboard → Connection string (with SSL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Required for AI decorate (Expo app, client-side Gemini) ─────────────────
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional: phone / device pointing at your computer’s API
# EXPO_PUBLIC_API_URL=http://192.168.x.x:4000

# ── Google Sign-In (paste OAuth client IDs only) ────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# 1. Create a "Web application" client → EXPO_PUBLIC_GOOGLE_CLIENT_ID
# 2. (Optional) iOS client → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
# 3. (Optional) Android client → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
# Authorized redirect URIs for Expo: use the Expo AuthSession redirect
#   (shown in console when you first press Continue with Google).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional Facebook Login
EXPO_PUBLIC_FACEBOOK_APP_ID=

# ── Gmail forgot-password (App Password only — not your normal Gmail password)
# 1. Use a Gmail account with 2-Step Verification ON
# 2. Google Account → Security → App passwords → generate for "Mail"
# 3. Paste the 16-character password as MAIL_PASSWORD
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ── Paystack Pro plan (Ghana) ───────────────────────────────────────────────
# Paystack Dashboard → Settings → API Keys → Secret Key
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# Amount in pesewas (5000 = GH₵50.00)
PRO_PLAN_AMOUNT_PESWAS=5000
PAYSTACK_CALLBACK_URL=decoraigh://billing/callback

# ── Optional: Google Maps (directions on place-map) ─────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# Also paste the same key into app.json ios.config.googleMapsApiKey
# and android.config.googleMaps.apiKey if you use native maps builds.
